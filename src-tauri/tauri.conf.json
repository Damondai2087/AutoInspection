{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AutoInspection",
  "version": "1.0.2",
  "identifier": "com.souvc.autoinspection",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AutoInspection 主机巡检",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/scripts/linux_inspect.sh": "resources/scripts/linux_inspect.sh",
      "resources/scripts/win_inspection_html.py": "resources/scripts/win_inspection_html.py",
      "resources/python/**/*": "resources/python/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
